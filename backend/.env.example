# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# JWT
JWT_SECRET=change-me-strong-secret-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-here
JWT_REFRESH_EXPIRES_IN=30d

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=finanzas_latam
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=finanzas-latam-uploads

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Encryption (AES-256 for sensitive fields, must be 32 chars)
ENCRYPTION_KEY=change-me-32-char-secret-key-here
